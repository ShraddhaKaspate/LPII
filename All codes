# Graph Coloring
graph = {
    0: [1, 2],
    1: [0, 2, 3],
    2: [0, 1, 3],
    3: [1, 2]
}
color = {}
colors = ["Red", "Green", "Blue"]
def safe(node, c):
    for neighbor in graph[node]:
        if neighbor in color and color[neighbor] == c:
            return False
    return True
def solve(node):
    if node == len(graph):
        print(color)
        return
    for c in colors:
        if safe(node, c):
            color[node] = c
            solve(node + 1)
            del color[node]
