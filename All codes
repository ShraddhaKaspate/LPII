AI 3. - Simple 4-Queens using A* idea

import heapq
def safe(board, row, col):
    for r in range(row):
        c = board[r]
        if c == col or abs(c - col) == abs(r - row):
            return False
    return True
def astar():
    pq = []
    heapq.heappush(pq, (0, []))
    while pq:
        cost, board = heapq.heappop(pq)
        row = len(board)
        if row == 4:
            return board
        for col in range(4):
            if safe(board, row, col):
                new_board = board + [col]
                heapq.heappush(pq, (len(new_board), new_board))
answer = astar()
print("Queen Positions:", answer)
